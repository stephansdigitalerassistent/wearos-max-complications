<?xml version="1.0" encoding="utf-8"?>
<!--
    Big Complication Watch Face
    
    Design philosophy: Maximum screen real-estate for ONE complication.
    Elderly-friendly: High contrast, warm colors, large text, no thin fonts.
    
    Layout (450x450 circle):
    - Time: Compact bar at top center (y=12, 38px warm white)
    - Complication: Fills ~80% of remaining screen (y=62 to y=422)
    
    Supported complication types: LONG_TEXT, SHORT_TEXT, RANGED_VALUE,
    MONOCHROMATIC_IMAGE, SMALL_IMAGE, PHOTO_IMAGE
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- TIME: Compact 24h clock at top center        -->
        <!-- Warm white (#FFF5F0E0) for elderly readability -->
        <!-- ============================================ -->
        <DigitalClock x="125" y="10" width="200" height="48">
            <TimeText x="0" y="0" width="200" height="48" format="hh:mm" align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="38" color="#FFF5F0E0" />
            </TimeText>
        </DigitalClock>

        <!-- ============================================ -->
        <!-- SINGLE MEGA COMPLICATION                     -->
        <!-- Fills the vast majority of the watch face    -->
        <!-- x=15, y=62, 420x360 = ~80% of screen area   -->
        <!-- ============================================ -->
        <ComplicationSlot 
            slotId="1" 
            supportedTypes="PHOTO_IMAGE LONG_TEXT RANGED_VALUE SHORT_TEXT MONOCHROMATIC_IMAGE SMALL_IMAGE" 
            x="15" y="62" 
            width="420" height="360">
            
            <BoundingOval x="0" y="0" width="420" height="360" />
            
            <DefaultProviderPolicy 
                defaultSystemProvider="DAY_AND_DATE" 
                defaultSystemProviderType="LONG_TEXT" />

            <!-- ======================================== -->
            <!-- LONG_TEXT: Title + large body text        -->
            <!-- Primary use case: weather, calendar, etc -->
            <!-- ======================================== -->
            <Complication type="LONG_TEXT">
                <Group x="0" y="0" width="420" height="360">
                    <!-- Title -->
                    <PartText x="10" y="40" width="400" height="60" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <!-- Main text — large for readability -->
                    <PartText x="10" y="110" width="400" height="200" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="40" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- SHORT_TEXT: Large centered text + title  -->
            <!-- Use case: step count, battery, timer     -->
            <!-- ======================================== -->
            <Complication type="SHORT_TEXT">
                <Group x="0" y="0" width="420" height="360">
                    <!-- Title -->
                    <PartText x="10" y="60" width="400" height="60" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <!-- Main text — extra large -->
                    <PartText x="10" y="130" width="400" height="160" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="52" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- RANGED_VALUE: Value text + title         -->
            <!-- Use case: step goal, heart rate zones    -->
            <!-- Simplified: text only, no arc (avoids    -->
            <!-- expression parsing issues)               -->
            <!-- ======================================== -->
            <Complication type="RANGED_VALUE">
                <Group x="0" y="0" width="420" height="360">
                    <!-- Title -->
                    <PartText x="10" y="60" width="400" height="50" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <!-- Value text — big and centered -->
                    <PartText x="10" y="120" width="400" height="160" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="56" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- MONOCHROMATIC_IMAGE: Large tinted icon   -->
            <!-- Use case: app shortcuts, status icons    -->
            <!-- ======================================== -->
            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="0" y="0" width="420" height="360">
                    <PartImage x="110" y="80" width="200" height="200"
                        tintColor="#FFFFCC00">
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- SMALL_IMAGE: Fills complication area     -->
            <!-- Use case: contact photos, app icons      -->
            <!-- ======================================== -->
            <Complication type="SMALL_IMAGE">
                <Group x="0" y="0" width="420" height="360">
                    <PartImage x="60" y="30" width="300" height="300">
                        <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- PHOTO_IMAGE: Full-bleed photo            -->
            <!-- Use case: personal photos, album art     -->
            <!-- ======================================== -->
            <Complication type="PHOTO_IMAGE">
                <Group x="0" y="0" width="420" height="360">
                    <PartImage x="10" y="0" width="400" height="360">
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

    </Scene>
</WatchFace>
