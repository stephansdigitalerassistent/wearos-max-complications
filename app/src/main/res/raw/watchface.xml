<?xml version="1.0" encoding="utf-8"?>
<!--
    Big Complication Watch Face - Fixed Performance & Settings
    
    Design philosophy: ONE mega complication + highly readable clock.
    Features: User-customizable color themes (Warm, Modern, High Contrast).
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <!-- ============================================ -->
    <!-- USER CONFIGURATIONS: Shows up in Watch App  -->
    <!-- ============================================ -->
    <UserConfigurations>
        <ColorConfiguration id="themeColor" defaultValue="0" displayName="Color Theme">
            <!-- Warm Gold (Elderly Friendly) -->
            <ColorOption id="0" displayName="Warm Gold" colors="#FFFFCC00 #FFF5F0E0" />
            <!-- Modern White -->
            <ColorOption id="1" displayName="Modern White" colors="#FFFFFFFF #FFCCCCCC" />
            <!-- High Contrast (Standard) -->
            <ColorOption id="2" displayName="Contrast" colors="#FF00FF00 #FFFFFFFF" />
        </ColorConfiguration>
    </UserConfigurations>

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- SINGLE MEGA COMPLICATION                     -->
        <!-- Reduced size slightly to clear status bars   -->
        <!-- ============================================ -->
        <ComplicationSlot 
            slotId="1" 
            supportedTypes="PHOTO_IMAGE LONG_TEXT RANGED_VALUE SHORT_TEXT MONOCHROMATIC_IMAGE SMALL_IMAGE" 
            x="25" y="70" 
            width="400" height="300">
            
            <BoundingOval x="0" y="0" width="400" height="300" />
            
            <DefaultProviderPolicy 
                defaultSystemProvider="DAY_AND_DATE" 
                defaultSystemProviderType="LONG_TEXT" />

            <!-- LONG_TEXT -->
            <Complication type="LONG_TEXT">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="20" width="400" height="60" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="[CONFIGURATION.themeColor.0]" weight="NORMAL" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="90" width="400" height="180" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="48" color="#FFFFFFFF" weight="NORMAL" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- SHORT_TEXT -->
            <Complication type="SHORT_TEXT">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="30" width="400" height="60" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="[CONFIGURATION.themeColor.0]" weight="NORMAL" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="100" width="400" height="150" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="56" color="#FFFFFFFF" weight="NORMAL" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- RANGED_VALUE -->
            <Complication type="RANGED_VALUE">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="30" width="400" height="50" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="[CONFIGURATION.themeColor.0]" weight="NORMAL" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="90" width="400" height="160" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="60" color="#FFFFFFFF" weight="NORMAL" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- MONOCHROMATIC_IMAGE -->
            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="0" y="0" width="400" height="300">
                    <PartImage x="100" y="50" width="200" height="200" tintColor="[CONFIGURATION.themeColor.0]">
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- PHOTO_IMAGE -->
            <Complication type="PHOTO_IMAGE">
                <Group x="0" y="0" width="400" height="300">
                    <PartImage x="0" y="0" width="400" height="300">
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

        <!-- ============================================ -->
        <!-- TIME: Bottom anchored clock                  -->
        <!-- ============================================ -->
        <DigitalClock x="75" y="370" width="300" height="70">
            <TimeText x="0" y="0" width="300" height="70" format="hh:mm" align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="52" color="[CONFIGURATION.themeColor.1]" weight="NORMAL" />
            </TimeText>
        </DigitalClock>

    </Scene>
</WatchFace>
