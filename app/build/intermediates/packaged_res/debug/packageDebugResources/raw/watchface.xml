<?xml version="1.0" encoding="utf-8"?>
<!--
    Big Complication Watch Face
    
    Design philosophy: Maximum screen real-estate for ONE complication.
    Elderly-friendly: High contrast, warm colors, large text.
    
    Layout (450x450 circle):
    - Complication: Fills the entire 450x450 screen (photo goes edge to edge)
    - Safe Zone: Text inside complication starts at y=70 to clear battery/DND icons.
    - Time: Rendered as a massive semi-transparent watermark overlaid on the complication.
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- SINGLE MEGA COMPLICATION (Drawn First)       -->
        <!-- Fills the entire watch face (450x450)        -->
        <!-- ============================================ -->
        <ComplicationSlot 
            slotId="1" 
            supportedTypes="PHOTO_IMAGE LONG_TEXT RANGED_VALUE SHORT_TEXT MONOCHROMATIC_IMAGE SMALL_IMAGE" 
            x="0" y="0" 
            width="450" height="450">
            
            <BoundingOval x="0" y="0" width="450" height="450" />
            
            <DefaultProviderPolicy 
                defaultSystemProvider="DAY_AND_DATE" 
                defaultSystemProviderType="LONG_TEXT" />

            <!-- ======================================== -->
            <!-- LONG_TEXT: Title + large body text        -->
            <!-- ======================================== -->
            <Complication type="LONG_TEXT">
                <Group x="0" y="0" width="450" height="450">
                    <!-- Title (y=70 clears the safe zone) -->
                    <PartText x="25" y="70" width="400" height="60" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <!-- Main text -->
                    <PartText x="25" y="140" width="400" height="200" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="48" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- SHORT_TEXT: Large centered text + title  -->
            <!-- ======================================== -->
            <Complication type="SHORT_TEXT">
                <Group x="0" y="0" width="450" height="450">
                    <PartText x="25" y="80" width="400" height="60" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <PartText x="25" y="150" width="400" height="150" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="56" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- RANGED_VALUE: Value text + title         -->
            <!-- ======================================== -->
            <Complication type="RANGED_VALUE">
                <Group x="0" y="0" width="450" height="450">
                    <PartText x="25" y="80" width="400" height="50" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <PartText x="25" y="140" width="400" height="160" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="60" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- MONOCHROMATIC_IMAGE: Large tinted icon   -->
            <!-- ======================================== -->
            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="0" y="0" width="450" height="450">
                    <PartImage x="125" y="125" width="200" height="200"
                        tintColor="#FFFFCC00">
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- SMALL_IMAGE: Large central image         -->
            <!-- ======================================== -->
            <Complication type="SMALL_IMAGE">
                <Group x="0" y="0" width="450" height="450">
                    <PartImage x="100" y="100" width="250" height="250">
                        <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- ======================================== -->
            <!-- PHOTO_IMAGE: Full-bleed background photo -->
            <!-- ======================================== -->
            <Complication type="PHOTO_IMAGE">
                <Group x="0" y="0" width="450" height="450">
                    <PartImage x="0" y="0" width="450" height="450">
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

        <!-- ============================================ -->
        <!-- TIME: Bottom anchored, highly readable       -->
        <!-- fully opaque warm white for elderly          -->
        <!-- ============================================ -->
        <DigitalClock x="75" y="360" width="300" height="70">
            <TimeText x="0" y="0" width="300" height="70" format="hh:mm" align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="52" color="#FFF5F0E0" weight="BOLD" />
            </TimeText>
        </DigitalClock>

    </Scene>
</WatchFace>
