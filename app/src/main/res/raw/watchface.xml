<?xml version="1.0" encoding="utf-8"?>
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- COMPLICATION SLOT (Full Screen Tap Target)   -->
        <!-- x=0 y=0 w=450 h=450: Touch anywhere to trigger-->
        <!-- ============================================ -->
        <ComplicationSlot
            slotId="1"
            supportedTypes="MONOCHROMATIC_IMAGE SMALL_IMAGE PHOTO_IMAGE"
            x="0" y="0"
            width="450" height="450">

            <!-- Full screen tap target for maximum simplicity -->
            <BoundingOval x="0" y="0" width="450" height="450" />

            <DefaultProviderPolicy
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="MONOCHROMATIC_IMAGE" />

            <!-- MONOCHROMATIC_IMAGE: centered icon at bottom -->
            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="45" y="250" width="360" height="150">
                    <PartImage x="105" y="0" width="150" height="150" tintColor="#FFFFCC00">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- SMALL_IMAGE: centered image at bottom -->
            <Complication type="SMALL_IMAGE">
                <Group x="45" y="250" width="360" height="150">
                    <PartImage x="105" y="0" width="150" height="150">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- PHOTO_IMAGE: full-screen photo at bottom -->
            <Complication type="PHOTO_IMAGE">
                <Group x="45" y="250" width="360" height="150">
                    <PartImage x="0" y="0" width="360" height="150">
                        <Variant mode="AMBIENT" target="alpha" value="80" />
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

        <!-- ============================================ -->
        <!-- TIME: Simplified Single Group (y=60, HUGE)   -->
        <!-- Font size increased to 100px BOLD            -->
        <!-- ============================================ -->
        <Group x="25" y="60" width="400" height="115" alpha="255">
            <DigitalClock x="0" y="0" width="400" height="115">
                <TimeText x="0" y="0" width="400" height="115" format="hh:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="100" color="#FFF5F0E0" weight="BOLD" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- ============================================ -->
        <!-- DATE: Below Time (amber accent, y=180, Bolder)-->
        <!-- Font size increased to 34px                  -->
        <!-- ============================================ -->
        <Group x="25" y="180" width="400" height="50">
            <Variant mode="AMBIENT" target="alpha" value="160" />
            <PartText x="0" y="0" width="400" height="50" align="CENTER">
                <Text>
                    <Font family="SYNC_TO_DEVICE" size="34" color="#FFFFCC00" weight="NORMAL" />
                    <Template>%s, %s %s<Parameter expression="[DAY_OF_WEEK_S]"/><Parameter expression="[DAY]"/><Parameter expression="[MONTH_S]"/></Template>
                </Text>
            </PartText>
        </Group>

    </Scene>
</WatchFace>
