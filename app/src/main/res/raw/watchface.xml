<?xml version="1.0" encoding="utf-8"?>
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- COMPLICATION SLOT (Center-Bottom)            -->
        <!-- ============================================ -->
        <ComplicationSlot
            slotId="1"
            supportedTypes="SHORT_TEXT LONG_TEXT RANGED_VALUE MONOCHROMATIC_IMAGE SMALL_IMAGE PHOTO_IMAGE"
            x="45" y="240"
            width="360" height="170">

            <BoundingOval x="0" y="0" width="360" height="170" />

            <DefaultProviderPolicy
                defaultSystemProvider="STEP_COUNT"
                defaultSystemProviderType="SHORT_TEXT" />

            <Complication type="LONG_TEXT">
                <Group x="0" y="0" width="360" height="170">
                    <PartText x="0" y="10" width="360" height="40" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="55" width="360" height="105" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="180" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="42" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <Complication type="SHORT_TEXT">
                <Group x="0" y="0" width="360" height="170">
                    <PartText x="0" y="10" width="360" height="40" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="55" width="360" height="105" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="180" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="52" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <Complication type="RANGED_VALUE">
                <Group x="0" y="0" width="360" height="170">
                    <PartText x="0" y="10" width="360" height="35" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="22" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="50" width="360" height="110" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="180" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="52" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="0" y="0" width="360" height="170">
                    <PartImage x="95" y="10" width="170" height="150" tintColor="#FFFFCC00">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <Complication type="SMALL_IMAGE">
                <Group x="0" y="0" width="360" height="170">
                    <PartImage x="95" y="10" width="170" height="150">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <Complication type="PHOTO_IMAGE">
                <Group x="0" y="0" width="360" height="170">
                    <PartImage x="0" y="0" width="360" height="170">
                        <Variant mode="AMBIENT" target="alpha" value="80" />
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

        <!-- ============================================ -->
        <!-- TIME: ACTIVE MODE (Center-Top, y=80)         -->
        <!-- ============================================ -->
        <Group x="25" y="80" width="400" height="100" alpha="255">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <DigitalClock x="0" y="0" width="400" height="100">
                <TimeText x="0" y="0" width="400" height="100" format="HH:mm" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="80" color="#FFFFFFFF" weight="BOLD" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- ============================================ -->
        <!-- TIME: AMBIENT MODE (Center-Top, y=80)        -->
        <!-- ============================================ -->
        <Group x="25" y="80" width="400" height="100" alpha="0">
            <Variant mode="AMBIENT" target="alpha" value="255" />
            <DigitalClock x="0" y="0" width="400" height="100">
                <TimeText x="0" y="0" width="400" height="100" format="HH:mm" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="80" color="#FFFFFFFF" weight="NORMAL" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- ============================================ -->
        <!-- DATE: Below Time (amber accent, y=175)       -->
        <!-- Uses PartText with Tag Expressions to avoid  -->
        <!-- DigitalClock parse/render crash.             -->
        <!-- ============================================ -->
        <Group x="25" y="175" width="400" height="45">
            <Variant mode="AMBIENT" target="alpha" value="160" />
            <PartText x="0" y="0" width="400" height="45" align="CENTER">
                <Text>
                    <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" weight="NORMAL" />
                    <Template>%s, %s %s<Parameter expression="[DAY_OF_WEEK_S]"/><Parameter expression="[DAY]"/><Parameter expression="[MONTH_S]"/></Template>
                </Text>
            </PartText>
        </Group>

    </Scene>
</WatchFace>
