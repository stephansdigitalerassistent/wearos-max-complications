<?xml version="1.0" encoding="utf-8"?>
<!--
    Big Complication Watch Face — Elderly-Friendly Edition
    
    Design principles:
    - Huge 96px time (HH:mm) at center-top for instant readability
    - Date below time for temporal orientation
    - Single complication (default: step count) at center-bottom
    - Full-screen tap target: touch ANYWHERE to trigger the complication
    - No configuration options (zero cognitive load at setup)
    - High-contrast white-on-black with warm amber accents
    - Ambient mode uses NORMAL weight (not THIN) for aging eyes
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <!-- No UserConfigurations — one optimal theme, zero setup complexity -->

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- COMPLICATION SLOT (Center-Bottom)            -->
        <!-- Full-screen tap: touch anywhere to trigger.  -->
        <!-- Rendered FIRST so time/date draw on top.     -->
        <!-- ============================================ -->
        <ComplicationSlot
            slotId="1"
            supportedTypes="SHORT_TEXT LONG_TEXT RANGED_VALUE MONOCHROMATIC_IMAGE SMALL_IMAGE PHOTO_IMAGE"
            x="0" y="0"
            width="450" height="450">

            <!-- Full-screen bounding rect: tap ANYWHERE to trigger -->
            <BoundingRect x="0" y="0" width="450" height="450" />

            <DefaultProviderPolicy
                defaultSystemProvider="STEP_COUNT"
                defaultSystemProviderType="SHORT_TEXT" />

            <!-- LONG_TEXT: title + text at center-bottom -->
            <Complication type="LONG_TEXT">
                <Group x="45" y="230" width="360" height="170">
                    <PartText x="0" y="10" width="360" height="40" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="55" width="360" height="105" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="180" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="42" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- SHORT_TEXT: title + large text at center-bottom -->
            <Complication type="SHORT_TEXT">
                <Group x="45" y="230" width="360" height="170">
                    <PartText x="0" y="10" width="360" height="40" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="55" width="360" height="105" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="180" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="52" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- RANGED_VALUE: title + value at center-bottom -->
            <Complication type="RANGED_VALUE">
                <Group x="45" y="230" width="360" height="170">
                    <PartText x="0" y="10" width="360" height="35" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="22" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="50" width="360" height="110" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="180" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="52" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- MONOCHROMATIC_IMAGE: centered icon at bottom -->
            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="45" y="230" width="360" height="170">
                    <PartImage x="80" y="5" width="200" height="160" tintColor="#FFFFCC00">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- SMALL_IMAGE: centered image at bottom -->
            <Complication type="SMALL_IMAGE">
                <Group x="45" y="230" width="360" height="170">
                    <PartImage x="80" y="5" width="200" height="160">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- PHOTO_IMAGE: full area photo at bottom -->
            <Complication type="PHOTO_IMAGE">
                <Group x="45" y="230" width="360" height="170">
                    <PartImage x="0" y="0" width="360" height="170">
                        <Variant mode="AMBIENT" target="alpha" value="80" />
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

        <!-- ============================================ -->
        <!-- TIME: ACTIVE MODE (Center-Top, HUGE)         -->
        <!-- 96px bold white — the dominant visual.       -->
        <!-- ============================================ -->
        <Group x="25" y="30" width="400" height="130" alpha="255">
            <!-- Hide completely in ambient -->
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <DigitalClock x="0" y="0" width="400" height="130">
                <TimeText x="0" y="0" width="400" height="130" format="HH:mm" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="96" color="#FFFFFFFF" weight="BOLD" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- ============================================ -->
        <!-- TIME: AMBIENT MODE (Center-Top, readable)    -->
        <!-- NORMAL weight — THIN is unreadable for       -->
        <!-- aging eyes with presbyopia.                  -->
        <!-- ============================================ -->
        <Group x="25" y="30" width="400" height="130" alpha="0">
            <!-- Show only in ambient -->
            <Variant mode="AMBIENT" target="alpha" value="255" />
            <DigitalClock x="0" y="0" width="400" height="130">
                <TimeText x="0" y="0" width="400" height="130" format="HH:mm" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="96" color="#FFFFFFFF" weight="NORMAL" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- ============================================ -->
        <!-- DATE: Below Time (Active + Ambient)          -->
        <!-- Day-of-week + date for temporal orientation. -->
        <!-- Warm amber accent, dimmed in ambient.        -->
        <!-- ============================================ -->
        <Group x="25" y="155" width="400" height="45">
            <Variant mode="AMBIENT" target="alpha" value="160" />
            <DigitalClock x="0" y="0" width="400" height="45">
                <TimeText x="0" y="0" width="400" height="45" format="EEE, d MMM" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" weight="NORMAL" />
                </TimeText>
            </DigitalClock>
        </Group>

    </Scene>
</WatchFace>
