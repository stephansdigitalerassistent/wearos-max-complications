<?xml version="1.0" encoding="utf-8"?>
<!--
    Big Complication Watch Face
    
    Design: Maximum complication space + readable clock for elderly.
    Burn-in: Uses THIN weight + dim color in ambient for outline effect.
    Offload-safe: No dynamic color expressions to ensure Samsung MCU compatibility.
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- SINGLE MEGA COMPLICATION SLOT                -->
        <!-- ============================================ -->
        <ComplicationSlot 
            slotId="1" 
            supportedTypes="PHOTO_IMAGE LONG_TEXT RANGED_VALUE SHORT_TEXT MONOCHROMATIC_IMAGE SMALL_IMAGE" 
            x="25" y="70" 
            width="400" height="300">
            
            <BoundingOval x="0" y="0" width="400" height="300" />
            
            <DefaultProviderPolicy 
                defaultSystemProvider="DAY_AND_DATE" 
                defaultSystemProviderType="LONG_TEXT" />

            <!-- LONG_TEXT -->
            <Complication type="LONG_TEXT">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="20" width="400" height="60" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="90" width="400" height="180" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="48" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- SHORT_TEXT -->
            <Complication type="SHORT_TEXT">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="30" width="400" height="60" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="100" width="400" height="150" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="56" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- RANGED_VALUE -->
            <Complication type="RANGED_VALUE">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="30" width="400" height="50" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFFFCC00" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TITLE]" />
                            </Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="90" width="400" height="160" align="CENTER">
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="60" color="#FFFFFFFF" />
                            <Template>%s
                                <Parameter expression="[COMPLICATION.TEXT]" />
                            </Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <!-- MONOCHROMATIC_IMAGE -->
            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="0" y="0" width="400" height="300">
                    <PartImage x="100" y="50" width="200" height="200" tintColor="#FFFFCC00">
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- SMALL_IMAGE -->
            <Complication type="SMALL_IMAGE">
                <Group x="0" y="0" width="400" height="300">
                    <PartImage x="85" y="30" width="230" height="230">
                        <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- PHOTO_IMAGE -->
            <Complication type="PHOTO_IMAGE">
                <Group x="0" y="0" width="400" height="300">
                    <PartImage x="0" y="0" width="400" height="300">
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

        <!-- ============================================ -->
        <!-- TIME: ACTIVE MODE (Bold, warm white)         -->
        <!-- Visible in active, hidden in ambient         -->
        <!-- ============================================ -->
        <DigitalClock x="75" y="370" width="300" height="70" alpha="255">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <TimeText x="0" y="0" width="300" height="70" format="hh:mm" align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="52" color="#FFF5F0E0" weight="BOLD" />
            </TimeText>
        </DigitalClock>

        <!-- ============================================ -->
        <!-- TIME: AMBIENT MODE (Thin, dim = outline fx)  -->
        <!-- Hidden in active, visible in ambient         -->
        <!-- ============================================ -->
        <DigitalClock x="75" y="370" width="300" height="70" alpha="0">
            <Variant mode="AMBIENT" target="alpha" value="255" />
            <TimeText x="0" y="0" width="300" height="70" format="hh:mm" align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="52" color="#66F5F0E0" weight="THIN" />
            </TimeText>
        </DigitalClock>

    </Scene>
</WatchFace>
