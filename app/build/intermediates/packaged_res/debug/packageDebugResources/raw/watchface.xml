<?xml version="1.0" encoding="utf-8"?>
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- COMPLICATION SLOT (Center-Bottom)            -->
        <!-- Restricted to IMAGE types only (no text)     -->
        <!-- ============================================ -->
        <ComplicationSlot
            slotId="1"
            supportedTypes="MONOCHROMATIC_IMAGE SMALL_IMAGE PHOTO_IMAGE"
            x="45" y="240"
            width="360" height="170">

            <BoundingOval x="0" y="0" width="360" height="170" />

            <!-- Default to a clean Watch Battery icon -->
            <DefaultProviderPolicy
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="MONOCHROMATIC_IMAGE" />

            <!-- MONOCHROMATIC_IMAGE: centered icon at bottom -->
            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="0" y="0" width="360" height="170">
                    <PartImage x="95" y="10" width="170" height="150" tintColor="#FFFFCC00">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- SMALL_IMAGE: centered image at bottom -->
            <Complication type="SMALL_IMAGE">
                <Group x="0" y="0" width="360" height="170">
                    <PartImage x="95" y="10" width="170" height="150">
                        <Variant mode="AMBIENT" target="alpha" value="160" />
                        <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <!-- PHOTO_IMAGE: full area photo at bottom -->
            <Complication type="PHOTO_IMAGE">
                <Group x="0" y="0" width="360" height="170">
                    <PartImage x="0" y="0" width="360" height="170">
                        <Variant mode="AMBIENT" target="alpha" value="80" />
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

        <!-- ============================================ -->
        <!-- TIME: Simplified Single Group (y=80)         -->
        <!-- Uses same color and hh:mm format as minimal. -->
        <!-- ============================================ -->
        <Group x="25" y="80" width="400" height="100" alpha="255">
            <DigitalClock x="0" y="0" width="400" height="100">
                <TimeText x="0" y="0" width="400" height="100" format="hh:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="80" color="#FFF5F0E0" weight="BOLD" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- ============================================ -->
        <!-- DATE: Below Time (amber accent, y=175)       -->
        <!-- ============================================ -->
        <Group x="25" y="175" width="400" height="45">
            <Variant mode="AMBIENT" target="alpha" value="160" />
            <PartText x="0" y="0" width="400" height="45" align="CENTER">
                <Text>
                    <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" weight="NORMAL" />
                    <Template>%s, %s %s<Parameter expression="[DAY_OF_WEEK_S]"/><Parameter expression="[DAY]"/><Parameter expression="[MONTH_S]"/></Template>
                </Text>
            </PartText>
        </Group>

    </Scene>
</WatchFace>
