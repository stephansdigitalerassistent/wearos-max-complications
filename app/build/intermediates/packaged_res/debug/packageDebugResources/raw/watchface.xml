<?xml version="1.0" encoding="utf-8"?>
<!--
    Big Complication Watch Face
    Ambient Fix: Restoring complication visibility in AOD mode.
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <UserConfigurations>
        <ColorConfiguration id="themeColor" defaultValue="0" displayName="Color Theme">
            <ColorOption id="0" displayName="Warm" colors="#FFFFCC00 #FFF5F0E0" />
        </ColorConfiguration>
    </UserConfigurations>

    <Scene backgroundColor="#FF000000">

        <!-- ============================================ -->
        <!-- COMPLICATION SLOT                            -->
        <!-- ============================================ -->
        <ComplicationSlot 
            slotId="1" 
            supportedTypes="LONG_TEXT SHORT_TEXT RANGED_VALUE MONOCHROMATIC_IMAGE SMALL_IMAGE PHOTO_IMAGE" 
            x="25" y="70" 
            width="400" height="300">
            
            <BoundingOval x="0" y="0" width="400" height="300" />
            
            <DefaultProviderPolicy 
                defaultSystemProvider="DAY_AND_DATE" 
                defaultSystemProviderType="LONG_TEXT" />

            <Complication type="LONG_TEXT">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="20" width="400" height="60" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="90" width="400" height="180" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="48" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <Complication type="SHORT_TEXT">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="30" width="400" height="60" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="28" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="100" width="400" height="150" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="56" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <Complication type="RANGED_VALUE">
                <Group x="0" y="0" width="400" height="300">
                    <PartText x="0" y="30" width="400" height="50" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="24" color="#FFFFCC00" />
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Text>
                    </PartText>
                    <PartText x="0" y="90" width="400" height="160" align="CENTER">
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                        <Text>
                            <Font family="SYNC_TO_DEVICE" size="60" color="#FFFFFFFF" />
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Text>
                    </PartText>
                </Group>
            </Complication>

            <Complication type="MONOCHROMATIC_IMAGE">
                <Group x="0" y="0" width="400" height="300">
                    <PartImage x="100" y="50" width="200" height="200" tintColor="#FFFFCC00">
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                        <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <Complication type="SMALL_IMAGE">
                <Group x="0" y="0" width="400" height="300">
                    <PartImage x="85" y="30" width="230" height="230">
                        <Variant mode="AMBIENT" target="alpha" value="128" />
                        <Image resource="[COMPLICATION.SMALL_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

            <Complication type="PHOTO_IMAGE">
                <Group x="0" y="0" width="400" height="300">
                    <PartImage x="0" y="0" width="400" height="300">
                        <Variant mode="AMBIENT" target="alpha" value="64" />
                        <Image resource="[COMPLICATION.PHOTO_IMAGE]" />
                    </PartImage>
                </Group>
            </Complication>

        </ComplicationSlot>

        <!-- ============================================ -->
        <!-- TIME: ACTIVE MODE                            -->
        <!-- Bold, solid text. Invisible in ambient.      -->
        <!-- ============================================ -->
        <Group x="75" y="370" width="300" height="70" alpha="255">
            <!-- Hide completely in ambient -->
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <DigitalClock x="0" y="0" width="300" height="70">
                <TimeText x="0" y="0" width="300" height="70" format="hh:mm" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="52" color="#FFF5F0E0" weight="BOLD" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- ============================================ -->
        <!-- TIME: AMBIENT MODE (Outline Font)            -->
        <!-- Thin, dim text. Visible ONLY in ambient.     -->
        <!-- ============================================ -->
        <Group x="75" y="370" width="300" height="70" alpha="0">
            <!-- Show only in ambient -->
            <Variant mode="AMBIENT" target="alpha" value="255" />
            <DigitalClock x="0" y="0" width="300" height="70">
                <TimeText x="0" y="0" width="300" height="70" format="hh:mm" align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="52" color="#AAAAAA" weight="THIN" />
                </TimeText>
            </DigitalClock>
        </Group>

    </Scene>
</WatchFace>
